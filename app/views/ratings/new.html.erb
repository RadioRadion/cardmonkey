<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4">
      <h1 class="text-xl font-bold text-white">Évaluer votre échange</h1>
      <p class="text-indigo-100 text-sm mt-1">Échange #<%= @trade.id %> avec <%= @other_user.username %></p>
    </div>

    <div class="p-6">
      <%= form_with model: @rating, url: trade_ratings_path(@trade), class: "space-y-6" do |f| %>
        <% if @rating.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">Erreur(s) :</h3>
                <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                  <% @rating.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        <% end %>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-3">
            Comment s'est passé l'échange avec <%= @other_user.username %> ?
          </label>
          <div class="flex justify-center space-x-2" data-controller="rating">
            <% (1..5).each do |score| %>
              <label class="cursor-pointer">
                <%= f.radio_button :score, score,
                    class: "hidden",
                    data: { rating_target: "input", action: "change->rating#update" } %>
                <span class="star text-4xl text-gray-300 hover:text-yellow-400 transition-colors"
                      data-rating-target="star"
                      data-score="<%= score %>">
                  ★
                </span>
              </label>
            <% end %>
          </div>
          <div class="text-center mt-2">
            <span class="text-sm text-gray-500" data-rating-target="label">Sélectionnez une note</span>
          </div>
        </div>

        <div>
          <label for="rating_comment" class="block text-sm font-medium text-gray-700 mb-2">
            Commentaire (optionnel)
          </label>
          <%= f.text_area :comment,
              rows: 4,
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500",
              placeholder: "Partagez votre expérience avec les autres utilisateurs..." %>
          <p class="mt-1 text-sm text-gray-500">Maximum 500 caractères</p>
        </div>

        <div class="flex items-center justify-between pt-4 border-t">
          <%= link_to "Annuler", trade_path(@trade), class: "text-gray-600 hover:text-gray-900" %>
          <%= f.submit "Envoyer mon évaluation",
              class: "px-6 py-2 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-lg hover:from-indigo-500 hover:to-purple-500 focus:ring-4 focus:ring-purple-300 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const labels = {
      1: "Très insatisfait 😞",
      2: "Insatisfait 😕",
      3: "Correct 😐",
      4: "Satisfait 😊",
      5: "Très satisfait 🎉"
    };

    const stars = document.querySelectorAll('[data-rating-target="star"]');
    const inputs = document.querySelectorAll('[data-rating-target="input"]');
    const label = document.querySelector('[data-rating-target="label"]');

    function updateStars(score) {
      stars.forEach(star => {
        const starScore = parseInt(star.dataset.score);
        if (starScore <= score) {
          star.classList.remove('text-gray-300');
          star.classList.add('text-yellow-400');
        } else {
          star.classList.remove('text-yellow-400');
          star.classList.add('text-gray-300');
        }
      });
      if (labels[score]) {
        label.textContent = labels[score];
      }
    }

    stars.forEach(star => {
      star.addEventListener('mouseenter', function() {
        updateStars(parseInt(this.dataset.score));
      });
    });

    document.querySelector('.flex.justify-center')?.addEventListener('mouseleave', function() {
      const checked = document.querySelector('[data-rating-target="input"]:checked');
      if (checked) {
        updateStars(parseInt(checked.value));
      } else {
        updateStars(0);
        label.textContent = "Sélectionnez une note";
      }
    });

    inputs.forEach(input => {
      input.addEventListener('change', function() {
        updateStars(parseInt(this.value));
      });
    });
  });
</script>
